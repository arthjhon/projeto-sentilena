# ============================================================
# Projeto Sentinela — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# O arquivo .env.local NUNCA deve ser commitado no git.
# ============================================================

# --- Supabase ---
# Encontre em: painel Supabase → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- MQTT (HiveMQ ou broker próprio) ---
# Protocolo WebSocket seguro: wss://
VITE_MQTT_BROKER_URL=wss://seu-broker.exemplo.com:8884/mqtt
VITE_MQTT_USER=seu_usuario_mqtt
VITE_MQTT_PASS=sua_senha_mqtt
